# Haupt-App
class FitnessApp:
    def __init__(self):
        self.root = tk.Tk()
        self.root.title("Fitness App")
        self.create_main_menu()

    def create_main_menu(self):
        tk.Label(self.root, text="Willkommen zur Fitness App!", font=("Helvetica", 16)).pack(pady=10)
        tk.Button(self.root, text="TRAINING STARTEN", command=self.show_days).pack(pady=5)
        tk.Button(self.root, text="ÜBUNGEN A–Z", command=self.show_exercises).pack(pady=5)
        tk.Button(self.root, text="ERNÄHRUNG", command=self.show_nutrition).pack(pady=5)
        tk.Button(self.root, text="FORM ANALYSE", command=self.show_form_analysis).pack(pady=5)
        tk.Button(self.root, text="BEENDEN", command=self.root.quit).pack(pady=5)

    def show_days(self):
        window = tk.Toplevel(self.root)
        window.title("Trainingstage")
        tk.Label(window, text="Wähle einen Tag:", font=("Helvetica", 14)).pack(pady=5)
        for day in plan_data.keys():
            tk.Button(window, text=day, command=lambda d=day: self.show_workout(d)).pack(pady=2)

    def show_workout(self, day):
        window = tk.Toplevel(self.root)
        window.title(f"Training - {day}")
        tk.Label(window, text=f"Übungen für {day}:", font=("Helvetica", 14)).pack(pady=5)
        for exercise in plan_data[day]:
            tk.Label(window, text=exercise).pack()

    def show_exercises(self):
        window = tk.Toplevel(self.root)
        window.title("Übungen A–Z")
        tk.Label(window, text="Wähle eine Übung:", font=("Helvetica", 14)).pack(pady=5)
        listbox = tk.Listbox(window, height=15, width=50)
        listbox.pack(pady=5)
        for exercise in UEBUNGEN_A_Z.keys():
            listbox.insert(tk.END, exercise)
        def show_info(event):
            selection = listbox.get(listbox.curselection())
            messagebox.showinfo(selection, UEBUNGEN_A_Z[selection])
        listbox.bind('<<ListboxSelect>>', show_info)

    def show_nutrition(self):
        window = tk.Toplevel(self.root)
        window.title("Ernährungstipps")
        tips = [
            "Trinke ausreichend Wasser.",
            "Iss genügend Protein.",
            "Achte auf Ballaststoffe.",
            "Begrenze Zucker und Fast Food."
        ]
        tk.Label(window, text="Ernährungstipps:", font=("Helvetica", 14)).pack(pady=5)
        for tip in tips:
            tk.Label(window, text=tip).pack()

    def show_form_analysis(self):
        window = tk.Toplevel(self.root)
        window.title("Form Analyse")
        tk.Label(window, text="Lade ein Foto hoch, um die Form zu analysieren.").pack(pady=5)
        def load_file():
            file_path = filedialog.askopenfilename(filetypes=[("Image Files", "*.jpg *.png *.jpeg")])
            if file_path:
                messagebox.showinfo("Analyse Ergebnis", "Form ist gut! (Platzhalter)")
        tk.Button(window, text="Foto auswählen", command=load_file).pack(pady=5)

    def run(self):
        self.root.mainloop()

# App starten
if __name__ == "__main__":
    FitnessApp().run()