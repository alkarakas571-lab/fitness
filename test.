import tkinter as tk

# ===== Hauptfenster =====
root = tk.Tk()
root.title("Fitness Plan")
root.geometry("400x400")
root.config(bg="#1E1E1E")  # bestehende Hintergrundfarbe

# ===== Workout Pläne =====
workout_plan = {
    "Monday": [
        "Push Ups",
        "Pull Ups",
        "Squats",
        "Plank",
        "Lunges"
    ],
    "Tuesday": [
        "Cat Cow Pose",
        "Chair Step Up",
        "Wadenheben",
        "Russian Twist",
        "Side Bends"
    ],
    "Wednesday": [
        "Schrägbank Rudern",
        "Langhantel Rudern",
        "Bicep Curls",
        "Hammer Curls",
        "Russian Twist",
        "Side Bends"
    ],
    "Thursday": [
        "Burpees",
        "Mountain Climbers",
        "Jump Squats",
        "Sit Ups",
        "Leg Raises"
    ],
    "Friday": [
        "Bench Press",
        "Deadlift",
        "Overhead Press",
        "Dumbbell Flys",
        "Tricep Dips"
    ]
}

# ===== Labels für die GUI =====
day_label = tk.Label(root, text="Select a Day", font=("Arial", 16), bg="#1E1E1E", fg="#FFFFFF")
day_label.pack(pady=10)

exercise_labels = []
for i in range(6):  # Maximal 6 Übungen pro Tag
    lbl = tk.Label(root, text="", font=("Arial", 14), bg="#1E1E1E", fg="#FFFFFF")
    lbl.pack()
    exercise_labels.append(lbl)

# ===== Funktion zum Anzeigen des Trainingsplans =====
def show_workout(day):
    day_label.config(text=day)
    exercises = workout_plan.get(day, [])
    for i, lbl in enumerate(exercise_labels):
        if i < len(exercises):
            lbl.config(text=exercises[i])
        else:
            lbl.config(text="")

# ===== Buttons für die Wochentage =====
button_frame = tk.Frame(root, bg="#1E1E1E")
button_frame.pack(pady=20)

for day in ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"]:
    btn = tk.Button(
        button_frame,
        text=day,
        font=("Arial", 12),
        width=10,
        bg="#282828",
        fg="#FFFFFF",
        command=lambda d=day: show_workout(d)
    )
    btn.pack(side=tk.LEFT, padx=5)

# ===== Starten der GUI =====
root.mainloop()
